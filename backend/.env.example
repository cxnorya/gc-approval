NODE_ENV=production
PORT=3000

# 前端访问地址，用于钉钉通知跳转
FRONTEND_URL=https://app.example.com

# 允许访问后端的前端域名，多个域名用英文逗号分隔
CORS_ORIGINS=https://app.example.com,https://yourname.github.io

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gc_user
DB_PASSWORD=change_me
DB_NAME=gc_approval

# 钉钉配置，不使用钉钉时可以留空
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_CORP_ID=
DINGTALK_ROBOT_WEBHOOK=

# JWT 密钥，生产环境必须改成很长的随机字符串
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
